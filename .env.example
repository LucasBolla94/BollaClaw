# =============================================
# BollaClaw V0.1 - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env
#
# For advanced LLM config, use providers.json instead (see providers.example.json)

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321   # Comma-separated Telegram User IDs

# --- LLM Provider (default: claude) ---
# Supported: claude, gemini, deepseek, groq, openai, openrouter, grok
# For full flexibility, use providers.json instead of .env
LLM_PROVIDER=claude
ROUTER_PROVIDER=groq              # Provider for skill routing (cheap/fast)

# --- API Keys (add all you have — the system auto-detects available providers) ---

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Google (Gemini)
# GEMINI_API_KEY=AIza...
# GEMINI_MODEL=gemini-2.0-flash

# DeepSeek
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# Groq (LLM + Whisper STT)
GROQ_API_KEY=gsk_...
# GROQ_MODEL=llama-3.3-70b-versatile

# OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# OpenRouter (access 100+ models through one API)
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# xAI (Grok)
# XAI_API_KEY=xai-...
# XAI_MODEL=grok-2

# Fallback order (comma-separated provider names)
# FALLBACK_ORDER=claude,openrouter,groq

# --- Agent Config ---
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=20     # Number of recent messages to pass to LLM
SKILLS_DIR=.agents/skills # Path to skills directory

# --- Audio (STT/TTS) ---
STT_PROVIDER=groq_whisper
TTS_VOICE=pt-BR-ThalitaMultilingualNeural
AUTO_AUDIO_REPLY=true

# --- Admin Panel ---
ADMIN_ENABLED=true
ADMIN_PORT=3000
ADMIN_PASSWORD=change_me_please
ADMIN_HOST=0.0.0.0

# --- Paths ---
DATA_DIR=./data
TMP_DIR=./tmp
LOGS_DIR=./logs

# --- Logging ---
LOG_LEVEL=info   # debug | info | warn | error
