# =============================================
# BollaClaw V0.1 - Environment Configuration
# =============================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_USER_IDS=123456789,987654321   # Comma-separated Telegram User IDs

# --- LLM Provider (choose one as default: claude, gemini, deepseek, groq) ---
LLM_PROVIDER=claude

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Google (Gemini)
GEMINI_API_KEY=AIza...

# DeepSeek
DEEPSEEK_API_KEY=sk-...

# Groq (LLM + Whisper STT)
GROQ_API_KEY=gsk_...

# --- Agent Config ---
MAX_ITERATIONS=5
MEMORY_WINDOW_SIZE=20     # Number of recent messages to pass to LLM
SKILLS_DIR=.agents/skills # Path to skills directory

# --- Audio (STT/TTS) ---
# STT Provider: groq_whisper | local_whisper
STT_PROVIDER=groq_whisper
# TTS Voice (edge-tts)
TTS_VOICE=pt-BR-ThalitaMultilingualNeural
# Auto-reply with audio when user sends voice note
AUTO_AUDIO_REPLY=true

# --- Admin Panel ---
ADMIN_ENABLED=true
ADMIN_PORT=3000
ADMIN_PASSWORD=change_me_please   # Password for web admin panel
ADMIN_HOST=0.0.0.0                # Set to 127.0.0.1 if using nginx reverse proxy

# --- Paths ---
DATA_DIR=./data
TMP_DIR=./tmp
LOGS_DIR=./logs

# --- Logging ---
LOG_LEVEL=info   # debug | info | warn | error
